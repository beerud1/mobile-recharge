# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/recharge_agent

# Anthropic / Claude
ANTHROPIC_API_KEY=your_anthropic_api_key

# PaySprint (Recharge API)
PAYSPRINT_API_KEY=your_paysprint_api_key
PAYSPRINT_MEMBER_ID=your_member_id
PAYSPRINT_BASE_URL=https://sit.paysprint.in/service-api/api/v1   # sandbox
# PAYSPRINT_BASE_URL=https://paysprint.in/service-api/api/v1    # production

# Komparify (Operator Plans API)
KOMPARIFY_API_KEY=your_komparify_api_key
KOMPARIFY_BASE_URL=https://www.komparify.com/api

# PhonePe (UPI Payments)
PHONEPE_MERCHANT_ID=your_merchant_id
PHONEPE_SALT_KEY=your_salt_key
PHONEPE_SALT_INDEX=1
PHONEPE_BASE_URL=https://api-preprod.phonepe.com/apis/pg-sandbox  # sandbox
# PHONEPE_BASE_URL=https://api.phonepe.com/apis/hermes            # production
PHONEPE_REDIRECT_URL=https://yourdomain.com/payment/redirect
PHONEPE_CALLBACK_URL=https://yourdomain.com/webhooks/payment

# Gupshup (WhatsApp)
GUPSHUP_APP_NAME=your_gupshup_app_name
GUPSHUP_API_KEY=your_gupshup_api_key
GUPSHUP_WHATSAPP_NUMBER=your_whatsapp_business_number

# Platform commission config (percentage kept, rest passed to user as cashback)
PLATFORM_FEE_PERCENT=0.5
